# Neo4j — single store for the MVP (graph + vector index)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# Ollama — local LLM serving
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=qwen2.5:32b
LLM_MODEL_FAST=qwen2.5:7b
LLM_TEMPERATURE=0

# Embedding (BGE-M3 via Ollama; ST fallback uses BAAI/bge-m3)
EMBED_MODEL=bge-m3
EMBED_ST_MODEL=BAAI/bge-m3
# Set to 1 to allow embedding at runtime (Ollama call or model download).
ENABLE_EMBEDDING=0

# API / UI
API_BASE=http://localhost:8000

# Optional: one-time external LLM use for schema-mapping rule generation only.
OPENAI_API_KEY=
