# PostgreSQL + pgvector — single store for the MVP
POSTGRES_USER=lg
POSTGRES_PASSWORD=lg_password
POSTGRES_DB=lg_bom
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Ollama — local LLM serving
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=qwen2.5:32b
EMBED_MODEL=bge-m3

# Local embedding fallback (sentence-transformers); 1 = allow runtime embedding
ENABLE_EMBEDDING=0
EMBED_ST_MODEL=BAAI/bge-m3
