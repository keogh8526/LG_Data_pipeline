# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lg_bom
POSTGRES_USER=lg
POSTGRES_PASSWORD=lg_password

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Embedding
EMBED_MODEL=BAAI/bge-m3
# Set to 1 to allow the embedding model to download/load at runtime.
ENABLE_EMBEDDING=0

# LLM (schema mapping / agent) — optional
OPENAI_API_KEY=
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0
